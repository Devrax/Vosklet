{
  "name": "speaklet",
  "version": "1.0.0",
  "description": "Vosklet-based voice challenge toolkit for the browser: offline speech recognition (bundled monosklet/Vosklet engine) unified with on-device speaker verification. Microphone capture, enrollment, and verification in one API.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "vite build",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@jaehyun-ko/speaker-verification": "5.0.0",
    "onnxruntime-web": "1.16.3"
  },
  "devDependencies": {
    "vite": "7.3.6",
    "monosklet": "workspace:*"
  },
  "keywords": [
    "speech-recognition",
    "speaker-verification",
    "speaker-recognition",
    "voice",
    "vosk",
    "vosklet",
    "wasm",
    "webview",
    "capacitor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Devrax/Vosklet.git",
    "directory": "speaklet"
  },
  "license": "MIT"
}
